# ── Nginx 反向代理配置示例 ──
# 用于域名访问 + SSL
# 使用方法：sudo cp nginx.conf.example /etc/nginx/sites-available/million-forecast

upstream million_forecast {
    server 127.0.0.1:8502;
}

server {
    listen 80;
    server_name your-domain.com;  # 替换为你的域名

    client_max_body_size 100M;

    location / {
        proxy_pass http://million_forecast;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
        proxy_buffering off;
    }

    # Streamlit WebSocket
    location /_stcore/stream {
        proxy_pass http://million_forecast/_stcore/stream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }

    # 健康检查
    location /_stcore/health {
        proxy_pass http://million_forecast/_stcore/health;
    }
}
