# ── 百万竞猜 / Million Forecast Terminal ──
# 复制此文件为 .env 并修改配置

# 运行环境
APP_ENV=production

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8502

# 数据库路径（Docker 内部路径，不要修改）
DATABASE_PATH=/app/data/football.duckdb

# 目录配置
UPLOAD_DIR=/app/uploads
MODEL_DIR=/app/model_artifacts
LOG_DIR=/app/logs

# 项目根目录（Docker 内部路径）
FOOTBALL_MODEL_HOME=/app
